# Neon Postgres pooled connection string (Neon dashboard → Connection Details).
# Also set this as DATABASE_URL in your Vercel project env vars.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Optional: guards /api/admin/ingest so only you can trigger crawls.
INGEST_SECRET="choose-a-long-random-string"

# Optional: an NCBI API key raises the rate limit from 3 to 10 req/s (faster ingest).
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=""
